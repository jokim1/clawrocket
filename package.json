{
  "name": "nanoclaw",
  "version": "1.2.7",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "check:webapp": "node scripts/ensure-webapp-installed.mjs",
    "install:webapp": "node scripts/install-webapp.mjs",
    "install:all": "npm install && npm run install:webapp",
    "dev:web": "npm run check:webapp && npm --prefix webapp run dev",
    "build:web": "npm run check:webapp && npm --prefix webapp run build",
    "test:web": "npm run check:webapp && npm --prefix webapp run test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "node scripts/run-vitest.mjs run",
    "test:watch": "node scripts/run-vitest.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "exceljs": "^4.4.0",
    "grammy": "^1.39.3",
    "hono": "^4.12.7",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright-core": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.12.0",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.0.18",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.59.0"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
